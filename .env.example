APP_ENV=development
APP_PORT=8080
CORS_ALLOWED_ORIGINS=*                         # prod: https://yourdomain.com

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=geolink
POSTGRES_PASSWORD=geolink
POSTGRES_DB=geolink
POSTGRES_SSL_MODE=disable                      # prod: require

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka (KRaft mode — no Zookeeper)
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID_INDEXER=indexer-group
KAFKA_GROUP_ID_PERSONALIZER=personalizer-group

# Typesense
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=geolink-local-key
TYPESENSE_COLLECTION=geonames

# GeoNames data
GEONAMES_FILE_PATH=./data/allCountries.txt
GEONAMES_DOWNLOAD_URL=https://download.geonames.org/export/dump/allCountries.zip
GEONAMES_BATCH_SIZE=500

# Personalization feature flags
PERSONALIZATION_GLOBAL=true
VELOCITY_LIMIT=100
VELOCITY_WINDOW_SECONDS=60
IP_PROFILE_TTL_DAYS=30
RECENT_SEARCHES_LIMIT=10
SEARCH_CACHE_TTL_SECONDS=60                    # 0 to disable

# Admin
ADMIN_API_KEY=your-secret-key-here
